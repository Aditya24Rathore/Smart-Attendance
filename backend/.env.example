# MongoDB Configuration
# ⚠️ SECURITY: Never use these values in production!
# Generate secure values and keep them in .env (not in git)
MONGODB_URI=mongodb://localhost:27017/smart_attendance

# Server Configuration
PORT=5000
NODE_ENV=development
# For production, comma-separate allowed frontend origins
# Example: CORS_ORIGIN=https://app.example.com,https://www.example.com
CORS_ORIGIN=http://localhost:3000

# Security Keys (Generate unique, secure values!)
# ⚠️ GENERATE NEW KEYS BEFORE PRODUCTION DEPLOYMENT
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
QR_ENCRYPTION_KEY=your_32_character_hex_encryption_key

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY=10

# Optional: Firebase Configuration (for SMS OTP)
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_AUTH_DOMAIN=

# Optional: Email Configuration (for email OTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Admin Credentials (DEVELOPMENT ONLY - Change in production)
# ⚠️ NEVER hardcode credentials. Use environment variables.
# Used by seedAdmin.js to create default admin account
ADMIN_EMAIL=admin@smartattendance.com
ADMIN_PASSWORD=<change_this_before_production>
